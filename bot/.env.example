# ── Anzen Telegram bot — configuration ──────────────────────────────
# Copy to ".env" and load it (e.g. `node --env-file=.env anzen-telegram-bot.js`
# on Node 20+, or `set -a; . ./.env; set +a` on older Node).

# Bot token from @BotFather (required for real sending).
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Path to the JSON exported from the app (Settings → Data backup → Backup now).
ANZEN_DATA_FILE=./anzen-data.json

# How often to check for due reminders (seconds).
CHECK_INTERVAL_SEC=60

# Reminder offsets — "minutesBefore:templateKey", comma-separated.
# 1440 = 24h (template lesson24), 60 = 1h (template lesson1).
REMINDER_OFFSETS_MIN=1440:lesson24,60:lesson1

# Template language: km or en.
LANG_PREF=km

# Set to 1 to log instead of actually sending (test without a token).
DRY_RUN=

# Optional: open an HTTP endpoint so the app/scripts can push the backup
# (POST /ingest). 0 = disabled.
INGEST_PORT=0
